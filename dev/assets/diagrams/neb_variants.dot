digraph neb_variants {
    rankdir=TB;
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=10, style=filled, margin="0.15,0.07"];
    edge [fontname="Helvetica", fontsize=8];
    label="NEB Method Variants: Oracle Call Reduction";
    labelloc=t;
    fontsize=14;
    nodesep=0.6;

    // Shared init
    init [label="Linear Interpolation\nN images between\nreactant \u2192 product", shape=box, fillcolor="#e8e8e8"];

    // Standard NEB
    subgraph cluster_standard {
        label="neb_optimize  (Standard NEB)";
        style=filled;
        color="#ffcc80";
        fillcolor="#fff3e0";

        std_eval [label="Oracle at ALL\nintermediate images\n(N-2 calls/iter)", shape=box, fillcolor="#ffcc80"];
        std_forces [label="Compute NEB forces\ntangent + spring", shape=box, fillcolor="#ffcc80"];
        std_step [label="Steepest descent\nimages += dt \u00b7 F", shape=box, fillcolor="#ffcc80"];
        std_ci [label="Climbing Image\n(if activated)\nF_ci = -G + 2(G\u00b7\u03c4)\u03c4", shape=box, fillcolor="#ffe0b2"];
        std_conv [label="Converged?\nmax||F|| < tol", shape=diamond, fillcolor="#fff3e0"];
    }

    // GP-NEB-AIE
    subgraph cluster_aie {
        label="gp_neb_aie  (All Images Evaluated)";
        style=filled;
        color="#ffe599";
        fillcolor="#fffef0";

        aie_outer [label="OUTER: Oracle at ALL\nintermediate images\n(N-2 calls/outer iter)", shape=box, fillcolor="#ffe599"];
        aie_train [label="Train GP on\nall accumulated\noracle data", shape=box, fillcolor="#ffe599"];
        aie_inner [label="INNER: Relax path\non GP surface\n(many cheap steps)", shape=box, fillcolor="#fff9c4"];
        aie_forces [label="NEB forces\nfrom GP predictions", shape=box, fillcolor="#fff9c4"];
        aie_conv_inner [label="GP converged?", shape=diamond, fillcolor="#fffef0"];
        aie_conv_outer [label="True forces\nconverged?", shape=diamond, fillcolor="#fffef0"];
    }

    // GP-NEB-OIE
    subgraph cluster_oie {
        label="gp_neb_oie  (One Image Evaluated)";
        style=filled;
        color="#c8e6c9";
        fillcolor="#f0fff0";

        oie_select [label="Select image with\nhighest GP uncertainty\n\u03c3\u00b2_max", shape=box, fillcolor="#c8e6c9"];
        oie_eval [label="OUTER: Oracle at\nSINGLE image\n(1 call/outer iter)", shape=box, fillcolor="#c8e6c9"];
        oie_train [label="Train GP on\nall accumulated\noracle data", shape=box, fillcolor="#c8e6c9"];
        oie_inner [label="INNER: Relax path\non GP surface", shape=box, fillcolor="#e8f5e9"];
        oie_forces [label="NEB forces\nfrom GP predictions", shape=box, fillcolor="#e8f5e9"];
        oie_conv [label="True forces\nconverged?", shape=diamond, fillcolor="#f0fff0"];
    }

    // Cost comparison
    subgraph cluster_cost {
        label="Oracle Call Comparison";
        style=filled;
        color="#e1d5e7";
        fillcolor="#f9f5ff";
        rank=same;

        cost_std [label="Standard NEB\n(N-2) \u00d7 iterations\n\u2248 hundreds of calls", shape=box, fillcolor="#ffcc80"];
        cost_aie [label="GP-NEB-AIE\n(N-2) \u00d7 outer_iters\n\u2248 tens of calls", shape=box, fillcolor="#ffe599"];
        cost_oie [label="GP-NEB-OIE\n1 \u00d7 outer_iters\n\u2248 few calls", shape=box, fillcolor="#c8e6c9"];
    }

    // Edges - Standard
    init -> std_eval;
    std_eval -> std_forces -> std_ci -> std_step -> std_conv;
    std_conv -> std_eval [label="no", style=dashed];

    // Edges - AIE
    init -> aie_outer;
    aie_outer -> aie_train -> aie_inner -> aie_forces -> aie_conv_inner;
    aie_conv_inner -> aie_inner [label="no", style=dashed];
    aie_conv_inner -> aie_conv_outer [label="yes"];
    aie_conv_outer -> aie_outer [label="no", style=dashed];

    // Edges - OIE
    init -> oie_select;
    oie_select -> oie_eval -> oie_train -> oie_inner -> oie_forces -> oie_conv;
    oie_conv -> oie_select [label="no", style=dashed];

    // Cost arrows
    cost_std -> cost_aie [label="fewer", style=bold, color="#339933"];
    cost_aie -> cost_oie [label="fewer", style=bold, color="#339933"];
}
