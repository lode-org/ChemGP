digraph gp_pipeline {
    rankdir=LR;
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=10, style=filled, margin="0.15,0.07"];
    edge [fontname="Helvetica", fontsize=8];
    label="GP Training & Prediction Pipeline";
    labelloc=t;
    fontsize=14;

    // Input
    oracle [label="Oracle\n(expensive)", shape=doubleoctagon, fillcolor="#f5b7b1"];
    coords [label="Coordinates\nx \u2208 R\u00b3\u1d3a", shape=ellipse, fillcolor="#e8e8e8"];

    // Training data
    subgraph cluster_training {
        label="Training Data Accumulation";
        style=filled;
        color="#d5e8d4";
        fillcolor="#f0fff0";

        add_point [label="add_point!\n(x, E, G)", shape=box, fillcolor="#a8d5a2"];
        td [label="TrainingData\nX: D\u00d7N\nenergies: N\ngradients: D\u00b7N", shape=box3d, fillcolor="#a8d5a2"];
        normalize_op [label="normalize\n\u2192 zero-mean\n\u2192 unit-var", shape=box, fillcolor="#a8d5a2"];
    }

    // Kernel evaluation
    subgraph cluster_kernel {
        label="Kernel Computation";
        style=filled;
        color="#dceefb";
        fillcolor="#f0f7ff";

        inv_dist [label="compute_\ninverse_distances\nf = 1/r\u1d62\u2c7c", shape=box, fillcolor="#b3d9ff"];
        kernel_eval [label="k(x\u1d62, x\u2c7c)\n\u03c3\u00b2 \u00b7 K(f(x\u1d62), f(x\u2c7c))", shape=box, fillcolor="#b3d9ff"];
        kernel_blocks_op [label="kernel_blocks\n\u2202k/\u2202x via ForwardDiff\n\u2192 (k_ee, k_ef, k_fe, k_ff)", shape=box, fillcolor="#b3d9ff"];
    }

    // Covariance assembly
    subgraph cluster_cov {
        label="Covariance Assembly";
        style=filled;
        color="#fff2cc";
        fillcolor="#fffef0";

        build_cov [label="build_full_covariance\nN(1+D) \u00d7 N(1+D)\nSymmetric matrix", shape=box, fillcolor="#ffe599"];
        noise [label="+ \u03c3\u00b2\u2099I (energy)\n+ \u03c3\u00b2\u2098I (gradient)\n+ jitter", shape=box, fillcolor="#ffe599"];
    }

    // Training
    subgraph cluster_train {
        label="Hyperparameter Optimization";
        style=filled;
        color="#e1d5e7";
        fillcolor="#f9f5ff";

        log_ml [label="log marginal likelihood\nlog p(y|\u03b8)", shape=box, fillcolor="#d5b8e8"];
        nelder_mead [label="Nelder-Mead\n(Optim.jl)\noptimize \u03c3, \u03b8, \u03c3\u2099, \u03c3\u2098", shape=box, fillcolor="#d5b8e8"];
        param_handle [label="ParameterHandling\npack/unpack\npositive constraints", shape=box, fillcolor="#d5b8e8"];
    }

    // Prediction
    subgraph cluster_predict {
        label="GP Inference";
        style=filled;
        color="#fce4ec";
        fillcolor="#fff5f5";

        cholesky [label="Cholesky\nL = chol(K)", shape=box, fillcolor="#f5b7b1"];
        predict_op [label="predict\n\u03bc = k\u209c K\u207b\u00b9 y", shape=box, fillcolor="#f5b7b1"];
        predict_var [label="predict_with_variance\n\u03c3\u00b2 = k\u209c\u209c - k\u209cK\u207b\u00b9k\u209c\u1d40", shape=box, fillcolor="#f5b7b1"];

        output_E [label="E_pred", shape=ellipse, fillcolor="#e8e8e8"];
        output_G [label="G_pred", shape=ellipse, fillcolor="#e8e8e8"];
        output_var [label="\u03c3\u00b2_pred", shape=ellipse, fillcolor="#e8e8e8"];
    }

    // Edges
    coords -> oracle [label="evaluate"];
    oracle -> add_point [label="(E, G)"];
    coords -> add_point;
    add_point -> td;
    td -> normalize_op;

    normalize_op -> build_cov [label="y_norm"];
    inv_dist -> kernel_eval;
    kernel_eval -> kernel_blocks_op;
    kernel_blocks_op -> build_cov [label="block\nmatrices"];
    build_cov -> noise -> log_ml;

    log_ml -> nelder_mead;
    param_handle -> nelder_mead [dir=both];
    nelder_mead -> kernel_eval [label="updated\nparams", style=dashed, color="#993399"];

    noise -> cholesky;
    cholesky -> predict_op;
    cholesky -> predict_var;
    predict_op -> output_E;
    predict_op -> output_G;
    predict_var -> output_var;
}
