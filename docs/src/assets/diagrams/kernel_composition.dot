digraph kernel_composition {
    rankdir=TB;
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=10, style=filled, margin="0.15,0.07"];
    edge [fontname="Helvetica", fontsize=8];
    label="Kernel Composition & Feature Pipeline";
    labelloc=t;
    fontsize=14;

    // Input
    subgraph cluster_input {
        label="Input";
        style=filled;
        color="#e8e8e8";
        fillcolor="#f5f5f5";

        x_mov [label="Moving atoms\nx \u2208 R\u00b3\u1d3a\u2098\u1d52\u1d5b", shape=ellipse, fillcolor="#e8e8e8"];
        x_fro [label="Frozen atoms\nx_fro \u2208 R\u00b3\u1d3a\u1da0\u02b3\u1d52", shape=ellipse, fillcolor="#e8e8e8"];
    }

    // Feature computation
    subgraph cluster_features {
        label="Feature Computation  (invdist.jl)";
        style=filled;
        color="#dceefb";
        fillcolor="#f0f7ff";

        pairs_mm [label="Moving-Moving pairs\nN_mov(N_mov-1)/2\n1/r\u1d62\u2c7c", shape=box, fillcolor="#b3d9ff"];
        pairs_mf [label="Moving-Frozen pairs\nN_mov \u00d7 N_fro\n1/r\u1d62\u2c7c", shape=box, fillcolor="#b3d9ff"];
        features [label="Feature vector\nf = [1/r\u2081\u2082, 1/r\u2081\u2083, ..., 1/r\u2098\u209b]\nrotationally invariant", shape=box3d, fillcolor="#99ccff"];
    }

    // Kernel types
    subgraph cluster_base_kernels {
        label="Base Molecular Kernels";
        style=filled;
        color="#d5e8d4";
        fillcolor="#f0fff0";

        se [label="MolInvDistSE\n\u03c3\u00b2 exp(-\u2211 (\u03b8\u0394f)\u00b2)\nC\u221e smooth", shape=box, fillcolor="#a8d5a2"];
        mat52 [label="MolInvDistMatern52\n\u03c3\u00b2(1+\u221a5d+5d\u00b2/3)e\u207b\u221a\u2075\u1d48\nC\u00b2 smooth", shape=box, fillcolor="#a8d5a2"];
        mat32 [label="MolInvDistMatern32\n\u03c3\u00b2(1+\u221a3d)e\u207b\u221a\u00b3\u1d48\nC\u00b9 smooth", shape=box, fillcolor="#a8d5a2"];
    }

    // Lengthscale types
    subgraph cluster_lengthscale {
        label="Lengthscale Modes";
        style=filled;
        color="#fff2cc";
        fillcolor="#fffef0";

        iso [label="Isotropic\nsingle \u03b8 for all pairs", shape=box, fillcolor="#ffe599"];
        ard [label="Type-Aware (ARD)\n\u03b8\u1d62 per atom-type pair\nvia pair_map", shape=box, fillcolor="#ffe599"];
    }

    // Composite kernels
    subgraph cluster_composite {
        label="Composite Kernels";
        style=filled;
        color="#e1d5e7";
        fillcolor="#f9f5ff";

        offset [label="OffsetKernel(c)\nk(x,y) = c\nconstant baseline", shape=box, fillcolor="#d5b8e8"];
        sum_k [label="MolSumKernel(k1, k2)\nk(x,y) = k1(x,y) + k2(x,y)", shape=box, fillcolor="#d5b8e8"];
        prod_k [label="MolProductKernel(k1, k2)\nk(x,y) = k1(x,y) \u00d7 k2(x,y)", shape=box, fillcolor="#d5b8e8"];
    }

    // Usage examples
    subgraph cluster_examples {
        label="Example Compositions";
        style=filled;
        color="#fce4ec";
        fillcolor="#fff5f5";

        ex1 [label="SE + Offset\n= signal + DC baseline\nfor energy prediction", shape=box, fillcolor="#f5b7b1"];
        ex2 [label="Mat52 \u00d7 SE\n= envelope \u00d7 detail\nfor PES with varying roughness", shape=box, fillcolor="#f5b7b1"];
        ex3 [label="Sum(SE_short, SE_long)\n= multi-scale\nfor bonded + non-bonded", shape=box, fillcolor="#f5b7b1"];
    }

    // ForwardDiff
    forwarddiff [label="ForwardDiff.jl\nAutomatic differentiation\n\u2207\u2081\u2207\u2082 k(x\u2081,x\u2082)", shape=component, fillcolor="#ffd9b3"];

    // Edges
    x_mov -> pairs_mm;
    x_mov -> pairs_mf;
    x_fro -> pairs_mf;
    pairs_mm -> features;
    pairs_mf -> features;

    features -> se;
    features -> mat52;
    features -> mat32;

    se -> iso [dir=both, style=dashed, color="#999999"];
    se -> ard [dir=both, style=dashed, color="#999999"];
    mat52 -> iso [dir=both, style=dashed, color="#999999"];
    mat52 -> ard [dir=both, style=dashed, color="#999999"];
    mat32 -> iso [dir=both, style=dashed, color="#999999"];
    mat32 -> ard [dir=both, style=dashed, color="#999999"];

    se -> sum_k;
    offset -> sum_k;
    se -> prod_k;
    mat52 -> prod_k;

    sum_k -> ex1 [style=dashed, color="#993399"];
    prod_k -> ex2 [style=dashed, color="#993399"];
    sum_k -> ex3 [style=dashed, color="#993399"];

    se -> forwarddiff;
    mat52 -> forwarddiff;
    mat32 -> forwarddiff;
    sum_k -> forwarddiff;
    prod_k -> forwarddiff;
}
