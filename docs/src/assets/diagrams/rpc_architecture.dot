digraph rpc_architecture {
    rankdir=TB;
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=10, style=filled, shape=box, margin="0.15,0.07"];
    edge [fontname="Helvetica", fontsize=8];
    label="ChemGP RPC Integration Architecture";
    labelloc=t;
    fontsize=14;
    compound=true;

    // ChemGP Julia layer
    subgraph cluster_chemgp {
        label="ChemGP (Julia)";
        style=filled;
        color="#d5e8d4";
        fillcolor="#f0fff0";
        node [fillcolor="#a8d5a2"];

        optimizer [label="GP Optimizer\ngp_minimize / gp_dimer\ngp_neb / otgpd"];
        gp_model [label="GP Surrogate\ntrain_model! / predict"];
        oracle_fn [label="oracle(x) -> (E, G)\nMinimal oracle calls"];
    }

    // RPC client layer
    subgraph cluster_rpc_client {
        label="RPC Client (rpc.jl)";
        style=filled;
        color="#dceefb";
        fillcolor="#f0f7ff";
        node [fillcolor="#b3d9ff"];

        find_lib [label="find_rgpot_lib()\nAuto-discovery"];
        rpc_pot [label="RpcPotential\nccall to libpot_client_bridge"];
        make_oracle [label="make_rpc_oracle(pot)\nF -> G sign flip"];
        with_serv [label="with_potserv()\nTest harness"];
    }

    // Network boundary
    subgraph cluster_network {
        label="Cap'n Proto RPC (TCP)";
        style=dashed;
        color="#999999";
        node [fillcolor="#e8e8e8", shape=ellipse];

        capnp [label="ForceInput -> PotentialResult\nBinary serialization"];
    }

    // Server options
    subgraph cluster_servers {
        label="Potential Servers";
        style=filled;
        color="#fff2cc";
        fillcolor="#fffef0";
        node [fillcolor="#ffe599"];

        potserv [label="rgpot potserv\nLJ / CuH2"];
        eonclient [label="eonclient --serve\nAny eOn potential"];
    }

    // Potential backends
    subgraph cluster_potentials {
        label="Potential Backends";
        style=filled;
        color="#f8cecc";
        fillcolor="#fff5f5";
        node [fillcolor="#f5b7b1"];

        metatomic [label="Metatomic\nPyTorch / metatensor\nML models (.pt)"];
        lj [label="Lennard-Jones\n12-6 pairwise"];
        cuh2 [label="CuH2 EAM\nFortran"];
        eon_pots [label="EXT / VASP / LAMMPS\nXTB / ASE / ..."];
    }

    // Data flow
    optimizer -> gp_model [label="predict on\nGP surface", color="#339933"];
    gp_model -> oracle_fn [label="query oracle\nat selected x", color="#cc3333"];
    oracle_fn -> make_oracle [color="#3366cc"];

    find_lib -> rpc_pot [label="lib path", color="#666666", style=dashed];
    make_oracle -> rpc_pot [label="calculate(pot, x)", color="#3366cc"];
    with_serv -> rpc_pot [style=dashed, color="#666666", label="testing"];

    rpc_pot -> capnp [label="positions, atmnrs, box", color="#3366cc"];
    capnp -> potserv [label="energy, forces", color="#cc3333"];
    capnp -> eonclient [label="energy, forces", color="#cc3333"];

    potserv -> lj [color="#993399"];
    potserv -> cuh2 [color="#993399"];
    eonclient -> metatomic [color="#993399"];
    eonclient -> eon_pots [color="#993399"];

    // GP feedback loop
    oracle_fn -> gp_model [label="add_point!\n(E, G) training data", color="#cc9900", style=dashed];
}
