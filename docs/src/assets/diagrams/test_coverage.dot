digraph test_coverage {
    rankdir=LR;
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=10, style=filled, margin="0.15,0.07"];
    edge [fontname="Helvetica", fontsize=8];
    label="Test Suite Coverage Map";
    labelloc=t;
    fontsize=14;

    // Test files (left)
    subgraph cluster_tests {
        label="Test Files (test/)";
        style=filled;
        color="#e1d5e7";
        fillcolor="#f9f5ff";
        node [shape=box];

        t_kernels [label="test_kernels.jl\nreconstruction\ngeneralization", fillcolor="#d5b8e8"];
        t_lbfgs [label="test_lbfgs.jl\ndirection\ncircular buffer", fillcolor="#d5b8e8"];
        t_minimize [label="test_minimize.jl\nLJ equilibrium\nrandom cluster", fillcolor="#d5b8e8"];
        t_dimer [label="test_dimer.jl\ncurvature\nrot/trans forces", fillcolor="#d5b8e8"];
        t_neb [label="test_neb.jl\ntangents\nspring forces\nclimbing image", fillcolor="#d5b8e8"];
        t_otgpd [label="test_otgpd.jl\nadaptive convergence\noracle accounting", fillcolor="#d5b8e8"];
        t_mb [label="test_muller_brown.jl\npotential values\ngradient eval", fillcolor="#d5b8e8"];
        t_leps [label="test_leps.jl\n2D + 3D versions\nreactant/product", fillcolor="#d5b8e8"];
        t_dist [label="test_distances.jl\nlog distance\nRMSD", fillcolor="#d5b8e8"];
        t_emd [label="test_emd.jl\npermutation\ninvariance", fillcolor="#d5b8e8"];
        t_samp [label="test_sampling.jl\nspace-filling\ndata retention", fillcolor="#d5b8e8"];
        t_var [label="test_variance.jl\ncovariance props", fillcolor="#d5b8e8"];
        t_cpp [label="cpp_consistency.jl\n(optional)\nnumerical match", fillcolor="#e8d5f5", style="filled,dashed"];
    }

    // Source modules (right)
    subgraph cluster_src {
        label="Source Modules (src/)";
        style=filled;
        color="#d5e8d4";
        fillcolor="#f0fff0";
        node [shape=box3d];

        s_abstract [label="kernels/abstract.jl", fillcolor="#a8d5a2"];
        s_se [label="kernels/MolInvDistSE.jl", fillcolor="#a8d5a2"];
        s_mat52 [label="kernels/MolInvDistMat5_2.jl", fillcolor="#a8d5a2"];
        s_mat32 [label="kernels/MolInvDistMat3_2.jl", fillcolor="#a8d5a2"];
        s_const [label="kernels/ConstantKernel.jl", fillcolor="#a8d5a2"];
        s_sum [label="kernels/SumKernel.jl", fillcolor="#a8d5a2"];
        s_prod [label="kernels/ProductKernel.jl", fillcolor="#a8d5a2"];
        s_invdist [label="invdist.jl", fillcolor="#a8d5a2"];
        s_deriv [label="derivatives.jl", fillcolor="#a8d5a2"];
        s_types [label="types.jl", fillcolor="#a8d5a2"];
        s_func [label="functions.jl", fillcolor="#a8d5a2"];
        s_lbfgs [label="optimizers/lbfgs.jl", fillcolor="#a8d5a2"];
        s_trust [label="optimizers/trust_region.jl", fillcolor="#a8d5a2"];
        s_min [label="optimizers/minimize.jl", fillcolor="#a8d5a2"];
        s_dimer [label="optimizers/dimer.jl", fillcolor="#a8d5a2"];
        s_neb_t [label="optimizers/neb_types.jl", fillcolor="#a8d5a2"];
        s_neb_p [label="optimizers/neb_path.jl", fillcolor="#a8d5a2"];
        s_neb [label="optimizers/neb.jl", fillcolor="#a8d5a2"];
        s_otgpd [label="optimizers/otgpd.jl", fillcolor="#a8d5a2"];
        s_dist [label="distances.jl", fillcolor="#a8d5a2"];
        s_emd [label="distances_emd.jl", fillcolor="#a8d5a2"];
        s_samp [label="sampling.jl", fillcolor="#a8d5a2"];
        s_lj [label="oracles/lennard_jones.jl", fillcolor="#a8d5a2"];
        s_mb [label="oracles/muller_brown.jl", fillcolor="#a8d5a2"];
        s_leps [label="oracles/leps.jl", fillcolor="#a8d5a2"];
        s_rpc [label="oracles/rpc.jl", fillcolor="#ffcccc", style="filled,dashed"];
    }

    // Coverage edges
    t_kernels -> s_se;
    t_kernels -> s_mat52;
    t_kernels -> s_mat32;
    t_kernels -> s_const;
    t_kernels -> s_sum;
    t_kernels -> s_prod;
    t_kernels -> s_invdist;
    t_kernels -> s_deriv;
    t_kernels -> s_types;
    t_kernels -> s_func;

    t_lbfgs -> s_lbfgs;
    t_minimize -> s_min;
    t_minimize -> s_lj;
    t_minimize -> s_trust;
    t_dimer -> s_dimer;
    t_neb -> s_neb_t;
    t_neb -> s_neb_p;
    t_neb -> s_neb;
    t_otgpd -> s_otgpd;
    t_otgpd -> s_dimer;
    t_mb -> s_mb;
    t_leps -> s_leps;
    t_dist -> s_dist;
    t_emd -> s_emd;
    t_samp -> s_samp;
    t_samp -> s_dist;
    t_var -> s_func;
    t_var -> s_deriv;
    t_cpp -> s_abstract [style=dashed];

    // Legend
    subgraph cluster_legend {
        label="Legend";
        style=filled;
        color="#e8e8e8";
        fillcolor="#f5f5f5";
        node [shape=box, fontsize=9];

        leg_tested [label="Tested", fillcolor="#a8d5a2"];
        leg_untested [label="No dedicated test\n(RPC needs server)", fillcolor="#ffcccc", style="filled,dashed"];
        leg_optional [label="Optional test", fillcolor="#e8d5f5", style="filled,dashed"];
    }
}
