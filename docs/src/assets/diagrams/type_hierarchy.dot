digraph type_hierarchy {
    rankdir=BT;
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=10, style=filled, shape=record, margin="0.15,0.07"];
    edge [fontname="Helvetica", fontsize=8];
    label="ChemGP Type Hierarchy";
    labelloc=t;
    fontsize=14;

    // Abstract types (external)
    Kernel [label="{KernelFunctions.Kernel|abstract type}", fillcolor="#e8e8e8"];

    // Kernel types
    AbstractMoleculeKernel [
        label="{AbstractMoleculeKernel|signal_variance::T\linv_lengthscales::V\lfrozen_coords::F\lfeature_params_map::Vector\{Int\}}",
        fillcolor="#b3d9ff"
    ];

    MolInvDistSE [
        label="{MolInvDistSE\{T,V,F\}|SE kernel on 1/r features\lk = \u03c3\u00b2 exp(-\u03a3 (\u03b8\u0394f)\u00b2)}",
        fillcolor="#cce5ff"
    ];
    MolInvDistMatern52 [
        label="{MolInvDistMatern52\{T,V,F\}|Mat\u00e9rn 5/2 on 1/r\l(1+\u221a5d+5d\u00b2/3)exp(-\u221a5d)}",
        fillcolor="#cce5ff"
    ];
    MolInvDistMatern32 [
        label="{MolInvDistMatern32\{T,V,F\}|Mat\u00e9rn 3/2 on 1/r\l(1+\u221a3d)exp(-\u221a3d)}",
        fillcolor="#cce5ff"
    ];

    OffsetKernel [
        label="{OffsetKernel\{T\}|constant::T\lk(x,y) = constant}",
        fillcolor="#ffe599"
    ];
    MolSumKernel [
        label="{MolSumKernel\{K1,K2\}|k1::K1, k2::K2\lk(x,y) = k1(x,y) + k2(x,y)}",
        fillcolor="#ffe599"
    ];
    MolProductKernel [
        label="{MolProductKernel\{K1,K2\}|k1::K1, k2::K2\lk(x,y) = k1(x,y) * k2(x,y)}",
        fillcolor="#ffe599"
    ];

    // GP types
    GPModel [
        label="{GPModel\{Tk \<: Kernel\}|kernel::Tk\lX::Matrix\{Float64\}\ly::Vector\{Float64\}\lnoise_var::Float64\lgrad_noise_var::Float64\ljitter::Float64}",
        fillcolor="#a8d5a2"
    ];
    TrainingData [
        label="{TrainingData|X::Matrix\{Float64\}\lenergies::Vector\{Float64\}\lgradients::Vector\{Float64\}}",
        fillcolor="#a8d5a2"
    ];

    // Config types
    MinimizationConfig [
        label="{MinimizationConfig|trust_radius, conv_tol\lmax_iter, gp_opt_tol\lgp_train_iter, ...}",
        fillcolor="#d5b8e8"
    ];
    DimerConfig [
        label="{DimerConfig|T_force_true, T_force_gp\lrotation_method::Symbol\ltranslation_method::Symbol\llbfgs_memory, ...}",
        fillcolor="#d5b8e8"
    ];
    NEBConfig [
        label="{NEBConfig|images, spring_constant\lclimbing_image::Bool\lconv_tol, step_size, ...}",
        fillcolor="#d5b8e8"
    ];
    OTGPDConfig [
        label="{OTGPDConfig|T_dimer, T_dimer_gp_init\ldivisor_T_dimer_gp\lmax_training_points\linitial_rotation, ...}",
        fillcolor="#d5b8e8"
    ];

    // Result types
    MinimizationResult [
        label="{MinimizationResult|x_final, E_final, G_final\lconverged::Bool\loracle_calls::Int\ltrajectory, energies}",
        fillcolor="#f5b7b1"
    ];
    DimerResult [
        label="{DimerResult|state::DimerState\lconverged::Bool\loracle_calls::Int}",
        fillcolor="#f5b7b1"
    ];
    NEBResult [
        label="{NEBResult|path::NEBPath\lconverged::Bool\loracle_calls::Int}",
        fillcolor="#f5b7b1"
    ];
    OTGPDResult [
        label="{OTGPDResult|state::DimerState\lconverged::Bool\loracle_calls::Int\lhistory::Dict}",
        fillcolor="#f5b7b1"
    ];

    // State types
    DimerState [
        label="{DimerState|R::Vector  (midpoint)\lorient::Vector  (direction)\ldimer_sep::Float64}",
        fillcolor="#ffd9b3"
    ];
    NEBPath [
        label="{NEBPath|images::Vector\{Vector\}\lenergies::Vector\lgradients::Vector\{Vector\}\lspring_constant::Float64}",
        fillcolor="#ffd9b3"
    ];
    LBFGSHistory [
        label="{LBFGSHistory|m::Int (memory)\ls, y::Vector\{Vector\}\lcount::Int}",
        fillcolor="#ffd9b3"
    ];

    // Subtype edges
    AbstractMoleculeKernel -> Kernel [label="<:"];
    MolInvDistSE -> AbstractMoleculeKernel [label="<:"];
    MolInvDistMatern52 -> AbstractMoleculeKernel [label="<:"];
    MolInvDistMatern32 -> AbstractMoleculeKernel [label="<:"];
    OffsetKernel -> Kernel [label="<:"];
    MolSumKernel -> Kernel [label="<:"];
    MolProductKernel -> Kernel [label="<:"];

    // Composition edges
    MolSumKernel -> MolInvDistSE [style=dashed, dir=back, label="composes", color="#999999"];
    MolSumKernel -> OffsetKernel [style=dashed, dir=back, label="composes", color="#999999"];
    MolProductKernel -> MolInvDistSE [style=dashed, dir=back, label="composes", color="#999999"];

    // Config → Result
    MinimizationConfig -> MinimizationResult [style=dashed, dir=forward, label="produces", color="#993399"];
    DimerConfig -> DimerResult [style=dashed, dir=forward, label="produces", color="#993399"];
    NEBConfig -> NEBResult [style=dashed, dir=forward, label="produces", color="#993399"];
    OTGPDConfig -> OTGPDResult [style=dashed, dir=forward, label="produces", color="#993399"];
}
